# Never commit .env to version control

# Required
OPENAI_API_KEY=sk-...
DATABASE_URL=postgresql+asyncpg://qna:qna@localhost:5432/qna
JWT_SECRET=change-me-use-openssl-rand-hex-32

# Optional search / social features
GOOGLE_API_KEY=
GOOGLE_CX=

# Optional — defaults shown
REDIS_URL=redis://localhost:6379/0
LOG_LEVEL=info
ALLOWED_ORIGINS=http://localhost:8000
MLFLOW_ENABLED=false
MLFLOW_TRACKING_URL=http://localhost:5000
OPENAI_MODEL_ANALYSIS=gpt-5.4-2026-03-05
OPENAI_MODEL_FAST=gpt-5.4-mini-2026-03-17
